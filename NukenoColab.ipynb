    "# ── 4. Set your ngrok authtoken ───────────────────────────────────────────\n",
    "# Get free token at: https://dashboard.ngrok.com/get-started/your-authtoken\n",
    "from pyngrok import ngrok, conf\n",
    "\n",
    "NGROK_TOKEN = 'PASTE_YOUR_NGROK_TOKEN_HERE'  # ← paste your token\n",
    "ngrok.set_auth_token(NGROK_TOKEN)\n",
    "print('✅ ngrok configured')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── 5. Start server + create tunnel ──────────────────────────────────────\n",
    "import subprocess, threading, time\n",
    "from pyngrok import ngrok\n",
    "\n",
    "# Kill any existing tunnels\n",
    "ngrok.kill()\n",
    "\n",
    "# Start FastAPI in background\n",
    "server = subprocess.Popen(\n",
    "    ['uvicorn', 'main:app', '--host', '0.0.0.0', '--port', '10000'],\n",
    "    stdout=subprocess.PIPE, stderr=subprocess.STDOUT\n",
    ")\n",
    "time.sleep(3)  # wait for startup\n",
    "\n",
    "# Open public tunnel\n",
    "tunnel = ngrok.connect(10000)\n",
    "url = tunnel.public_url\n",
    "\n",
    "print('\\n' + '='*50)\n",
    "print(f'🌐 Nukeno is LIVE at:')\n",
    "print(f'   {url}')\n",
    "print('='*50)\n",
    "print('Share this link with anyone. Keep this tab open.')\n",
    "print('\\nPress Stop (■) to shut down.')"
   ],
   "execution_count": null,
   "outputs": []
  },
